{
  "name": "sidereal-dashboard",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm run build:shader-preview-wasm && pnpm run build:game-client-wasm",
    "dev": "vite dev --port 3000",
    "build:shader-preview-wasm": "node scripts/build-shader-preview-wasm.mjs",
    "build:game-client-wasm": "node scripts/build-game-client-wasm.mjs",
    "build": "pnpm run build:shader-preview-wasm && pnpm run build:game-client-wasm && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint src",
    "format": "prettier --check .",
    "check": "prettier --write . && eslint src --fix"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
